    <head>
        <title>December, 31 2022 Fulfillment Partner Payout</title>
    </head>
    <body>
        <img width=3D"300" data-responsive=3D"true" src=3D"http://cdn.mcaut=
o-images-production.sendgrid.net/5fd65cfc68aaebc5/ccd38630-af5c-46c4-a871-4=
